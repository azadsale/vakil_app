# =============================================================================
# Legal-CoPilot — .gitignore
# CRITICAL: .env must NEVER be committed (contains secrets + PII risk)
# =============================================================================

# Environment files
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml
*.cover

# Node / Next.js
node_modules/
.next/
out/
frontend/.env.local

# Docker volumes (local data — never commit)
postgres_data/
minio_data/
redis_data/

# Secrets
*.pem
*.key
*.p12
secrets/

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store

# Alembic — don't ignore versions, they are migration scripts
# alembic/versions/  ← intentionally NOT ignored