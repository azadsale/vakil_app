# =============================================================================
# Legal-CoPilot — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=vakil
POSTGRES_PASSWORD=vakilsecret           # Change in production
POSTGRES_DB=vakildb

# --- Backend / FastAPI ---
SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_32   # openssl rand -hex 32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Document Encryption ---
DOCUMENT_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_BASE64  # base64-encoded 32-byte key

# --- MinIO (local S3) ---
MINIO_ROOT_USER=vakilminio
MINIO_ROOT_PASSWORD=vakilminio123       # Change in production
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_DOCUMENTS=legal-documents
MINIO_SECURE=false                      # true when TLS termination is active

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- OCR Providers (configure one or both) ---
# Azure AI Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<resource>.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Google Document AI
GOOGLE_PROJECT_ID=
GOOGLE_PROCESSOR_ID=
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/google-sa.json

# --- Sarvam AI (Audio Transcription — Indian languages) ---
SARVAM_API_KEY=                         # Get from sarvam.ai — NEVER commit real key

# --- LlamaIndex / LLM ---
OPENAI_API_KEY=                         # Or use local Ollama endpoint
LLAMA_INDEX_EMBED_MODEL=text-embedding-ada-002
LLAMA_INDEX_LLM_MODEL=gpt-4o

# --- e-Courts ---
ECOURTS_BASE_URL=https://services.ecourts.gov.in

# --- Environment ---
ENVIRONMENT=development                 # development | staging | production
LOG_LEVEL=INFO